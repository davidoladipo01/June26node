<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <title>Document</title>
</head>
<body>
    <h1>This is an ejs file</h1>
    <%# ejsout %>

    

    <%= gender %>
    <%# conditional statements in ejs, looping in ejs, comments in ejs %>
    <% if (gender =="female") { %>
        <h1>This is a male</h1>
    <% } else { %>
        <h1>This is a female</h1>
    <% } %>

        <%# for loop, each %>
    <div class="d-flex gap-3 flex-wrap">
        <% for( let i = 0; i < students.length; i++ ) { %>
            <div class="card" style="width: 18rem;">
            <div class="card-body">
                <h5 class="card-title"><%= students[i].name %></h5>
                <h6 class="card-subtitle mb-2 text-body-secondary"><%= students[i].grade %></h6>
                <p class="card-text"><%= students[i].class %></p>
                <a href="#" class="btn btn-primary">Edit</a>
                <a href="#" class="btn btn-primary">Delete</a>
            </div>
            </div>
        <% } %>
    </div>

    <div class="d-flex flex-wrap">
        <% students.forEach((students, index) => { %>
            <div class="card" style="width: 18rem;">
            <div class="card-body">
                <h5 class="card-title"><%= students.name %></h5>
                <h6 class="card-subtitle mb-2 text-body-secondary"><%= students.grade %></h6>
                <p class="card-text"><%= students.class %></p>
                <form action="/editStudent/<%= index %>" method="post">
                    <button type="submit" class="btn btn-primary">Edit</button>
                </form>
                <form action="/delete/<%= index %>" method="post">
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
            <!-- <button></button> -->
            </div>
        <% }) %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>
</html>